[node name="Bullet1" type="Label" parent="Slide2/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Reports of a werewolf on campus"
autowrap_mode = 3

[node name="Bullet2" type="Label" parent="Slide2/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Werewolves are real and eat people"
autowrap_mode = 3

[node name="Sub2" type="Label" parent="Slide2/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.75, 1)
theme_override_font_sizes/font_size = 18
text = "      They are human-looking most of the time &
      can turn into wolf monsters
      — that part is not disputed within the game"
autowrap_mode = 3

[node name="Bullet3" type="Label" parent="Slide2/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Lots of conflicting information going around:"
autowrap_mode = 3

[node name="Sub3" type="Label" parent="Slide2/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.75, 1)
theme_override_font_sizes/font_size = 18
text = "      Is there really a monster?
      How do you recognize one? What are the signs?
      How can you protect yourself?"
autowrap_mode = 3

[node name="Bullet4" type="Label" parent="Slide2/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Use your knowledge and skills in real-world
   information evaluation to determine what is
   \"true\" in the game"
autowrap_mode = 3

