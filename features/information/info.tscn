autowrap_mode = 3

[node name="Bullet2" type="Label" parent="Slide1/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Learn to recognize well-meaning but less reliable
   information sources"
autowrap_mode = 3

[node name="Bullet3" type="Label" parent="Slide1/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Learn to recognize more reliable claims and/or sources"
autowrap_mode = 3

[node name="Bullet4" type="Label" parent="Slide1/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
