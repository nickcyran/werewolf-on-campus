[gd_scene format=3]

[ext_resource type="Script" path="res://features/phone/phone_app_icon.gd" id="1_icon"]

[node name="PhoneAppIcon" type="Control"]
custom_minimum_size = Vector2(120, 140)
layout_mode = 2
script = ExtResource("1_icon")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8
alignment = 1

[node name="IconButton" type="Button" parent="VBox"]
custom_minimum_size = Vector2(90, 90)
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 32
text = "?"

[node name="AppLabel" type="Label" parent="VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.82, 0.86, 1)
theme_override_font_sizes/font_size = 15
text = "App"
horizontal_alignment = 1
text_overrun_behavior = 3
