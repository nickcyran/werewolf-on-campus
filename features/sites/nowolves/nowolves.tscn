[node name="Body" type="RichTextLabel" parent="ScrollContainer/Content/BodySection/Article/ArticleContent" unique_id=575954383]
custom_minimum_size = Vector2(0, 445.335)
layout_mode = 2
theme_override_colors/default_color = Color(0.15, 0.15, 0.15, 1)
theme_override_fonts/normal_font = ExtResource("4_jmhreg")
theme_override_fonts/bold_font = ExtResource("3_jmhblack")
