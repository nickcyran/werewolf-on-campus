[node name="Title" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoTitleGold"
text = "The Process"

[node name="Bullet1" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Read through the documents in the packet"
autowrap_mode = 3

[node name="Sub1" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoSub"
text = "      Imagine them all as online sources / graphics
      Evaluate which ones are more reliable and which
      may be less trustworthy"
autowrap_mode = 3

[node name="Bullet2" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Some info is accurate, some is mis/disinformation"
autowrap_mode = 3

[node name="Sub2" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoSub"
text = "      You must determine which is which based on your
      knowledge of online misinformation"
autowrap_mode = 3

[node name="Bullet3" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Once you're ready, you can use the optional QR code
   to check your answers:"
autowrap_mode = 3

[node name="Sub3" type="Label" parent="Slide3/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoSub"
text = "      Is there a werewolf on campus?
      How would you identify one?"
autowrap_mode = 3

