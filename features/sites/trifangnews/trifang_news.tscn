theme_override_font_sizes/normal_font_size = 21
text = "Approximately 2:30pm on Wednesday, a werewolf sighting occurred. A clip gone viral shows an influencer encountering a creature in the campus tunnels.

Officers are closely examining the scene, finding piles of fur scattered throughout. If anyone can provide any information, please call 567-TRI-TFPD.

Campus security has increased patrols around the tunnel entrances, and administrators say a full statement will follow once the investigation concludes. Students are advised to avoid the area after dark until further notice."
fit_content = true
scroll_active = false

