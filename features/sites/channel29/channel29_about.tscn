[node name="BioBody" type="RichTextLabel" parent="ScrollContainer/Content/BodySection/MainContent/BioSection/BioVBox/MarginContainer" unique_id=310972692]
custom_minimum_size = Vector2(0, 280)
layout_mode = 2
theme_override_colors/default_color = Color(0.18, 0.18, 0.18, 1)
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "Mary Harker is a reporter with the rapid response team at Channel 29 News. Harker graduated magna cum laude with a degree in Journalism from Tri-Fang University in 2011. She worked at the student paper there and held an internship with the Tri-Fang City Herald before joining Channel 29 in 2016. She primarily covers public safety and topics of local concern for the Tri-City area. She won the Selden Ring Award in 2023 for her work exposing several members of the mayor's office as vampires."
scroll_active = false
