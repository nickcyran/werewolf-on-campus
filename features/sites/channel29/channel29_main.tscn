[node name="Body" type="RichTextLabel" parent="ScrollContainer/Content/BodySection/ArticleMargin/ArticleVBox" unique_id=750192844]
custom_minimum_size = Vector2(0, 300)
layout_mode = 2
theme_override_colors/default_color = Color(0.15, 0.15, 0.15, 1)
theme_override_font_sizes/normal_font_size = 16
bbcode_enabled = true
text = "Tri-Fang University officials are investigating a strange late-night incident reported by a student near the central campus courtyard on Friday evening.

According to the student, who was returning to their dorm after studying in the library, a large creature resembling a werewolf appeared near the biology building shortly after midnight. The student described the figure as tall, covered in dark fur, and emitting a low growl before disappearing into the wooded area behind campus.

Campus security responded to the scene but found no physical evidence of the creature. University officials stated that the report is being taken seriously while reminding students to travel in groups at night as the investigation continues."
scroll_active = false

