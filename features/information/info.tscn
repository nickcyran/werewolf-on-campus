[node name="Title" type="Label" parent="Slide1/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoTitleGold"
text = "The Goal"

[node name="Bullet1" type="Label" parent="Slide1/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Learn common propaganda / disinformation techniques
   that apply to all kinds of topics and mediums"
autowrap_mode = 3

[node name="Bullet2" type="Label" parent="Slide1/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Learn to recognize well-meaning but less reliable
   information sources"
autowrap_mode = 3

[node name="Bullet3" type="Label" parent="Slide1/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Learn to recognize more reliable claims and/or sources"
autowrap_mode = 3

[node name="Bullet4" type="Label" parent="Slide1/Scroll/Margin/VBox"]
layout_mode = 2
theme_type_variation = &"InfoBody"
text = "•  Have some fun in a more memorable way than talking
   about depressing real-world examples of mis &
   disinformation"
autowrap_mode = 3

