[node name="Bullet1" type="Label" parent="Slide3/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Read through the documents in the packet"
autowrap_mode = 3

[node name="Sub1" type="Label" parent="Slide3/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.75, 1)
theme_override_font_sizes/font_size = 18
text = "      Imagine them all as online sources / graphics
      Evaluate which ones are more reliable and which
      may be less trustworthy"
autowrap_mode = 3

[node name="Bullet2" type="Label" parent="Slide3/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Some info is accurate, some is mis/disinformation"
autowrap_mode = 3

[node name="Sub2" type="Label" parent="Slide3/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.75, 1)
theme_override_font_sizes/font_size = 18
text = "      You must determine which is which based on your
      knowledge of online misinformation"
autowrap_mode = 3

[node name="Bullet3" type="Label" parent="Slide3/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/font_size = 20
text = "•  Once you're ready, you can use the optional QR code
   to check your answers:"
autowrap_mode = 3

[node name="Sub3" type="Label" parent="Slide3/Margin/VBox"]
