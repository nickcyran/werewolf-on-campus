bbcode_enabled = true
text = "Mary Harker is a reporter with the rapid response team at Channel 29 News. Harker graduated magna cum laude with a degree in Journalism from Tri-Fang University in 2011.

She worked at the student paper there and held an internship with the Tri-Fang City Herald before joining Channel 29 in 2016.

She primarily covers public safety and topics of local concern for the Tri-City area.

She won the Selden Ring Award in 2023 for her work exposing several members of the mayor's office as vampires."
scroll_active = false
